{
  "name": "serverless-librato-alerts",
  "version": "5.0.19",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/serverless-plugins/serverless-librato-alerts.git"
  },
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "vp pack",
    "check:types": "tsc --noEmit",
    "test": "vp test run",
    "lint:code": "vp check",
    "lint:markdown": "markdownlint '*.md' '!(node_modules|dist|example|.beads)/**/*.md' --config=.github/linters/.markdown-lint.yml --fix",
    "lint": "pnpm run lint:code && pnpm run lint:markdown",
    "lint:fix": "vp check --fix && pnpm run lint:markdown",
    "prepublishOnly": "rm -rf dist && pnpm run build && pnpm run lint",
    "prepare": "vp config --no-agent"
  },
  "devDependencies": {
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/commit-analyzer": "13.0.1",
    "@semantic-release/git": "10.0.1",
    "@semantic-release/github": "12.0.9",
    "@semantic-release/npm": "13.1.5",
    "@semantic-release/release-notes-generator": "14.1.1",
    "@types/node": ">=26",
    "conventional-changelog-conventionalcommits": "10.2.1",
    "markdownlint-cli": "0.49.0",
    "publint": "0.3.21",
    "semantic-release": "25.0.5",
    "typescript": "7.0.2",
    "vite-plus": "0.2.4"
  },
  "engines": {
    "node": ">= 22"
  },
  "packageManager": "pnpm@11.11.0+sha512.4463f65fd80ed80d69bc1d4bf163ee94f605c7380fc318bb5b2ebe15f8cd12d49c51a4d59e951b401e764d3b6ca751cbf51bc50ed7001a6bcb4935e684c34882"
}
